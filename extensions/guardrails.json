{
  "policies": {
    "rules": [
      {
        "id": "example-secret-env-files",
        "name": "Secret env files",
        "description": "Block .env files and variants",
        "patterns": [
          {
            "pattern": ".env"
          },
          {
            "pattern": ".env.*"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": ".env.example"
          },
          {
            "pattern": "*.sample.env"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "enabled": true
      },
      {
        "id": "example-ssh-keys",
        "name": "SSH keys",
        "description": "Block SSH private key files",
        "patterns": [
          {
            "pattern": "*.pem"
          },
          {
            "pattern": "*_rsa"
          },
          {
            "pattern": "*_ed25519"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": "*.pub"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "enabled": true
      },
      {
        "id": "example-aws-credentials",
        "name": "AWS credentials",
        "description": "Block AWS credentials and config files",
        "patterns": [
          {
            "pattern": ".aws/credentials"
          },
          {
            "pattern": ".aws/config"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "enabled": true
      },
      {
        "id": "example-certificates",
        "name": "Certificates",
        "description": "Block certificate and key files",
        "patterns": [
          {
            "pattern": "*.crt"
          },
          {
            "pattern": "*.key"
          },
          {
            "pattern": "*.p12"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": "*.csr"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "enabled": true
      }
    ]
  },
  "permissionGate": {
    "patterns": [
      {
        "pattern": "git push --force",
        "description": "Git force push",
        "regex": true
      },
      {
        "pattern": "npm publish",
        "description": "NPM package publishing",
        "regex": true
      },
      {
        "pattern": "pnpm publish",
        "description": "PNPM package publishing",
        "regex": true
      },
      {
        "pattern": "DROP DATABASE",
        "description": "SQL database drop",
        "regex": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-04-11T08:09:26.788Z",
    "version": "0.9.0-20260327"
  }
}
